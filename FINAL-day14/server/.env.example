# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com (free M0 cluster)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/portfolio_evaluator

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: read:user, public_repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server configuration
PORT=5000

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# JWT Secret (optional, for future features)
JWT_SECRET=your_random_secret_key_here
